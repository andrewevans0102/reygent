{
  "name": "reygent-code",
  "version": "0.1.0",
  "description": "Agentic coding tool for software development",
  "type": "module",
  "main": "./dist/cli.js",
  "module": "./dist/cli.js",
  "exports": {
    ".": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "reygent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "verify:publish": "npm pack && npm link",
    "release:prepare": "./scripts/release.sh prepare",
    "release:tag": "./scripts/release.sh tag"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewevans0102/reygent.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@inquirer/core": "^10.2.1",
    "@inquirer/prompts": "^8.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "marked": "^18.0.3",
    "ora": "^9.3.0",
    "yaml": "^2.8.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
